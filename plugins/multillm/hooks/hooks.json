{
  "description": "Start the MultiLLM gateway automatically on Claude session start",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/start-gateway.sh",
            "timeout": 15,
            "statusMessage": "Starting MultiLLM gateway..."
          }
        ]
      }
    ]
  }
}
